---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
).slice(0, 3);

function formatDate(date: Date) {
  return date.toLocaleDateString('en-US', {
    year: 'numeric',
    month: 'short',
    day: 'numeric'
  });
}
---

<BaseLayout title="Gonçalo Velosa - Building AI Agents In Public">
  <!-- Hero Section -->
  <section class="max-w-7xl mx-auto px-6 lg:px-12 py-24 md:py-32 lg:py-48 flex flex-col md:flex-row items-start justify-between gap-12">
    <!-- Main Content (75%) -->
    <div class="md:w-3/4">
      <p class="text-primary text-sm font-label tracking-widest uppercase mb-6">
        Software Engineer & AI Enthusiast
      </p>
      
      <h1 class="text-5xl md:text-7xl lg:text-8xl font-black tracking-tighter leading-[0.9] mb-8">
        HI, I'M GONÇALO.<br/>
        <span class="text-on-surface-variant">BUILDING AI AGENTS</span><br/>
        <span class="bg-gradient-to-r from-primary to-primary-container bg-clip-text text-transparent">IN PUBLIC.</span>
      </h1>
      
      <p class="text-xl text-on-surface-variant max-w-2xl leading-relaxed mb-12">
        Backend developer with a passion for AI agents, blockchain, and building systems that scale. 
        I craft autonomous solutions and explore the intersection of technology and real-world problems.
        Currently focused on multi-agent architectures and self-improving systems.
      </p>
      
      <div class="flex flex-col sm:flex-row gap-4">
        <a href="/projects" class="btn-primary">
          VIEW PROJECTS
        </a>
        <a href="/contact" class="btn-secondary">
          GET IN TOUCH
        </a>
      </div>
    </div>
    
    <!-- Decorative Element (25%) -->
    <div class="hidden md:block w-1/4 pt-12">
      <div class="h-64 w-px bg-gradient-to-b from-primary to-transparent opacity-20 mx-auto"></div>
      <div class="mt-8 font-label text-[10px] tracking-[0.3em] uppercase text-on-surface-variant rotate-90 origin-left translate-x-4 whitespace-nowrap">
        ESTABLISHED 2024 / SYSTEM ACTIVE
      </div>
    </div>
  </section>

  <!-- Tech Stack Section (Bento Grid) -->
  <section class="bg-surface-container-low py-24 md:py-32 px-6 lg:px-12">
    <div class="max-w-7xl mx-auto">
      <!-- Section Header -->
      <div class="mb-12">
        <h2 class="text-3xl font-bold tracking-tighter uppercase mb-2">Technical Arsenal</h2>
        <div class="h-1 w-12 bg-primary"></div>
      </div>
      
      <!-- Bento Grid -->
      <div class="grid grid-cols-1 md:grid-cols-4 gap-4 md:gap-6">
        <!-- Backend (2 cols) -->
        <div class="md:col-span-2 p-6 md:p-8 bg-surface-container rounded-lg border border-outline-variant/5 hover:bg-surface-container-high transition-all">
          <svg class="w-10 h-10 text-primary mb-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 12h14M5 12a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v4a2 2 0 01-2 2M5 12a2 2 0 00-2 2v4a2 2 0 002 2h14a2 2 0 002-2v-4a2 2 0 00-2-2m-2-4h.01M17 16h.01"/>
          </svg>
          <h3 class="text-xl font-bold mb-3">Backend Engineering</h3>
          <p class="text-on-surface-variant text-sm mb-6">Scalable architectures with clean separation and DDD principles.</p>
          <div class="flex flex-wrap gap-2">
            <span class="text-[10px] px-3 py-1 bg-surface-container-lowest text-primary rounded-full uppercase tracking-wider font-label">Node.js</span>
            <span class="text-[10px] px-3 py-1 bg-surface-container-lowest text-primary rounded-full uppercase tracking-wider font-label">TypeScript</span>
            <span class="text-[10px] px-3 py-1 bg-surface-container-lowest text-primary rounded-full uppercase tracking-wider font-label">Python</span>
          </div>
        </div>
        
        <!-- Frontend (1 col) -->
        <div class="p-6 md:p-8 bg-surface-container rounded-lg border border-outline-variant/5 hover:bg-surface-container-high transition-all">
          <svg class="w-10 h-10 text-primary mb-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
          </svg>
          <h3 class="text-xl font-bold mb-3">Frontend</h3>
          <p class="text-on-surface-variant text-sm mb-6">Modern interfaces.</p>
          <div class="flex flex-wrap gap-2">
            <span class="text-[10px] px-3 py-1 bg-surface-container-lowest text-primary rounded-full uppercase tracking-wider font-label">Next.js</span>
            <span class="text-[10px] px-3 py-1 bg-surface-container-lowest text-primary rounded-full uppercase tracking-wider font-label">React</span>
            <span class="text-[10px] px-3 py-1 bg-surface-container-lowest text-primary rounded-full uppercase tracking-wider font-label">Astro</span>
          </div>
        </div>
        
        <!-- Database (1 col) -->
        <div class="p-6 md:p-8 bg-surface-container rounded-lg border border-outline-variant/5 hover:bg-surface-container-high transition-all">
          <svg class="w-10 h-10 text-primary mb-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 7v10c0 2.21 3.582 4 8 4s8-1.79 8-4V7M4 7c0 2.21 3.582 4 8 4s8-1.79 8-4M4 7c0-2.21 3.582-4 8-4s8 1.79 8 4m0 5c0 2.21-3.582 4-8 4s-8-1.79-8-4"/>
          </svg>
          <h3 class="text-xl font-bold mb-3">Data</h3>
          <p class="text-on-surface-variant text-sm mb-6">Persistence layers.</p>
          <div class="flex flex-wrap gap-2">
            <span class="text-[10px] px-3 py-1 bg-surface-container-lowest text-primary rounded-full uppercase tracking-wider font-label">PostgreSQL</span>
            <span class="text-[10px] px-3 py-1 bg-surface-container-lowest text-primary rounded-full uppercase tracking-wider font-label">Redis</span>
          </div>
        </div>
        
        <!-- Blockchain (2 cols) -->
        <div class="md:col-span-2 p-6 md:p-8 bg-surface-container rounded-lg border border-outline-variant/5 hover:bg-surface-container-high transition-all">
          <svg class="w-10 h-10 text-primary mb-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z"/>
          </svg>
          <h3 class="text-xl font-bold mb-3">Blockchain / Web3</h3>
          <p class="text-on-surface-variant text-sm mb-6">Smart contracts and DeFi protocols on EVM networks.</p>
          <div class="flex flex-wrap gap-2">
            <span class="text-[10px] px-3 py-1 bg-surface-container-lowest text-primary rounded-full uppercase tracking-wider font-label">Solidity</span>
            <span class="text-[10px] px-3 py-1 bg-surface-container-lowest text-primary rounded-full uppercase tracking-wider font-label">Foundry</span>
            <span class="text-[10px] px-3 py-1 bg-surface-container-lowest text-primary rounded-full uppercase tracking-wider font-label">EVM</span>
            <span class="text-[10px] px-3 py-1 bg-surface-container-lowest text-primary rounded-full uppercase tracking-wider font-label">OpenZeppelin</span>
          </div>
        </div>
        
        <!-- AI/ML (1 col) -->
        <div class="p-6 md:p-8 bg-surface-container rounded-lg border border-outline-variant/5 hover:bg-surface-container-high transition-all">
          <svg class="w-10 h-10 text-primary mb-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"/>
          </svg>
          <h3 class="text-xl font-bold mb-3">AI / ML</h3>
          <p class="text-on-surface-variant text-sm mb-6">LLM integrations.</p>
          <div class="flex flex-wrap gap-2">
            <span class="text-[10px] px-3 py-1 bg-surface-container-lowest text-primary rounded-full uppercase tracking-wider font-label">OpenAI</span>
            <span class="text-[10px] px-3 py-1 bg-surface-container-lowest text-primary rounded-full uppercase tracking-wider font-label">Anthropic</span>
          </div>
        </div>
        
        <!-- Cloud (1 col) -->
        <div class="p-6 md:p-8 bg-surface-container rounded-lg border border-outline-variant/5 hover:bg-surface-container-high transition-all">
          <svg class="w-10 h-10 text-primary mb-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 15a4 4 0 004 4h9a5 5 0 10-.1-9.999 5.002 5.002 0 10-9.78 2.096A4.001 4.001 0 003 15z"/>
          </svg>
          <h3 class="text-xl font-bold mb-3">Cloud</h3>
          <p class="text-on-surface-variant text-sm mb-6">Infrastructure.</p>
          <div class="flex flex-wrap gap-2">
            <span class="text-[10px] px-3 py-1 bg-surface-container-lowest text-primary rounded-full uppercase tracking-wider font-label">AWS</span>
            <span class="text-[10px] px-3 py-1 bg-surface-container-lowest text-primary rounded-full uppercase tracking-wider font-label">Docker</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Featured Projects Section -->
  <section class="py-24 md:py-32 px-6 lg:px-12 max-w-7xl mx-auto">
    <div class="flex justify-between items-end mb-12">
      <div>
        <h2 class="text-3xl font-bold tracking-tighter uppercase mb-2">Featured Projects</h2>
        <p class="text-on-surface-variant">Selected work from the vault.</p>
      </div>
      <a href="/projects" class="text-xs tracking-widest uppercase text-primary border-b border-primary pb-1 hover:text-primary-dim transition-colors font-label hidden sm:block">
        View All →
      </a>
    </div>
    
    <div class="grid md:grid-cols-2 gap-6">
      <!-- OpenClaw -->
      <article class="card group">
        <div class="h-48 mb-6 rounded-lg overflow-hidden bg-gradient-to-br from-surface-container-high to-surface-container-lowest flex items-center justify-center">
          <svg class="w-16 h-16 text-primary opacity-20" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"/>
          </svg>
        </div>
        <p class="text-xs font-label text-primary uppercase tracking-widest mb-2">AI Agents</p>
        <h3 class="text-xl font-bold mb-2 group-hover:text-primary transition-colors">OpenClaw</h3>
        <p class="text-on-surface-variant text-sm mb-4">
          14-agent autonomous system for software development. From validation to deployment with specialized agents.
        </p>
        <a href="/projects" class="text-primary text-sm hover:underline">View Project →</a>
      </article>
      
      <!-- Trading System -->
      <article class="card group">
        <div class="h-48 mb-6 rounded-lg overflow-hidden bg-gradient-to-br from-surface-container-high to-surface-container-lowest flex items-center justify-center">
          <svg class="w-16 h-16 text-primary opacity-20" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"/>
          </svg>
        </div>
        <p class="text-xs font-label text-primary uppercase tracking-widest mb-2">Trading</p>
        <h3 class="text-xl font-bold mb-2 group-hover:text-primary transition-colors">Autonomous Trading System</h3>
        <p class="text-on-surface-variant text-sm mb-4">
          7-agent algorithmic trading with professional risk management. CRT strategy with 5 variations.
        </p>
        <a href="/projects" class="text-primary text-sm hover:underline">View Project →</a>
      </article>
    </div>
  </section>

  <!-- Latest Posts Section -->
  <section class="bg-surface-container-low py-24 md:py-32 px-6 lg:px-12">
    <div class="max-w-7xl mx-auto">
      <div class="flex justify-between items-end mb-12">
        <div>
          <h2 class="text-3xl font-bold tracking-tighter uppercase mb-2">Latest Posts</h2>
          <p class="text-on-surface-variant">Thoughts on AI, agents, and building in public.</p>
        </div>
        <a href="/blog" class="text-xs tracking-widest uppercase text-primary border-b border-primary pb-1 hover:text-primary-dim transition-colors font-label hidden sm:block">
          Read All →
        </a>
      </div>
      
      {posts.length > 0 ? (
        <div class="grid md:grid-cols-3 gap-6">
          {posts.map((post) => (
            <a href={`/blog/${post.id}`} class="card group">
              <div class="h-40 mb-6 rounded-lg overflow-hidden bg-gradient-to-br from-surface-container-high to-surface-container-lowest flex items-center justify-center">
                <span class="text-primary text-5xl font-black opacity-20">
                  {post.data.title.charAt(0)}
                </span>
              </div>
              <p class="text-xs font-label text-primary uppercase tracking-widest mb-2">
                {post.data.category}
              </p>
              <h3 class="text-lg font-bold mb-2 group-hover:text-primary transition-colors line-clamp-2">
                {post.data.title}
              </h3>
              <p class="text-on-surface-variant text-sm line-clamp-2 mb-4">
                {post.data.description}
              </p>
              <time class="text-xs text-neutral-500">
                {formatDate(post.data.pubDate)}
              </time>
            </a>
          ))}
        </div>
      ) : (
        <p class="text-on-surface-variant text-center py-12">Coming soon...</p>
      )}
    </div>
  </section>
</BaseLayout>
