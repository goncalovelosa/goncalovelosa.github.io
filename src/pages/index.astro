---
// index.astro - Homepage with hero, featured projects, and latest posts
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout>
  <!-- Hero Section -->
  <section class="min-h-[90vh] flex items-center justify-center px-6 lg:px-8">
    <div class="max-w-7xl mx-auto text-center">
      <!-- Headline -->
      <h1 class="text-4xl sm:text-5xl md:text-6xl lg:text-7xl font-bold tracking-tight mb-6">
        <span class="text-primary">Building AI Agents</span>
        <br />
        <span class="text-on-surface">In Public</span>
      </h1>

      <!-- Subtitle -->
      <p class="text-xl md:text-2xl text-on-surface-variant font-medium mb-4">
        Software Developer & AI Enthusiast
      </p>

      <!-- Description -->
      <p class="max-w-2xl mx-auto text-on-surface-variant text-lg mb-10 leading-relaxed">
        I'm Gonçalo Velosa, a developer passionate about building AI-powered solutions,
        automation systems, and exploring the intersection of technology and innovation.
        Currently focused on creating autonomous agents that solve real-world problems.
      </p>

      <!-- CTA Buttons -->
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a href="/projects" class="btn-primary">
          View Projects
        </a>
        <a href="/blog" class="btn-secondary">
          Read Blog
        </a>
      </div>
    </div>
  </section>

  <!-- Featured Projects Section -->
  <section class="section-gap px-6 lg:px-8">
    <div class="max-w-7xl mx-auto">
      <!-- Section Header -->
      <div class="flex items-center justify-between mb-12">
        <h2 class="text-3xl md:text-4xl font-bold text-on-surface">
          Featured <span class="text-primary">Projects</span>
        </h2>
        <a href="/projects" class="text-primary hover:text-primary-dim transition-colors font-medium hidden sm:block">
          View All &rarr;
        </a>
      </div>

      <!-- Projects Grid -->
      <div class="grid md:grid-cols-2 gap-6">
        <!-- OpenClaw Project -->
        <article class="card group cursor-pointer">
          <div class="flex items-start justify-between mb-4">
            <div class="p-3 bg-surface-container-high rounded-lg">
              <svg class="w-6 h-6 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4" />
              </svg>
            </div>
            <span class="text-xs font-label text-on-surface-variant bg-surface-container-highest px-3 py-1 rounded-full">
              Open Source
            </span>
          </div>
          <h3 class="text-xl font-bold text-on-surface mb-2 group-hover:text-primary transition-colors">
            OpenClaw
          </h3>
          <p class="text-on-surface-variant mb-4">
            An open-source legal document analysis tool powered by AI. Helps legal professionals
            process and understand complex legal documents efficiently.
          </p>
          <div class="flex items-center gap-4 text-sm text-on-surface-variant">
            <span class="flex items-center gap-1">
              <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
                <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
              </svg>
              Python
            </span>
            <span class="flex items-center gap-1">
              <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
                <path d="M12 .587l3.668 7.568 8.332 1.151-6.064 5.828 1.48 8.279-7.416-3.967-7.417 3.967 1.481-8.279-6.064-5.828 8.332-1.151z"/>
              </svg>
              128
            </span>
          </div>
        </article>

        <!-- Autonomous Trading System Project -->
        <article class="card group cursor-pointer">
          <div class="flex items-start justify-between mb-4">
            <div class="p-3 bg-surface-container-high rounded-lg">
              <svg class="w-6 h-6 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6" />
              </svg>
            </div>
            <span class="text-xs font-label text-on-surface-variant bg-surface-container-highest px-3 py-1 rounded-full">
              AI/ML
            </span>
          </div>
          <h3 class="text-xl font-bold text-on-surface mb-2 group-hover:text-primary transition-colors">
            Autonomous Trading System
          </h3>
          <p class="text-on-surface-variant mb-4">
            An AI-powered trading system that uses machine learning algorithms to analyze
            market patterns and execute trades autonomously with risk management.
          </p>
          <div class="flex items-center gap-4 text-sm text-on-surface-variant">
            <span class="flex items-center gap-1">
              <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
                <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
              </svg>
              Python
            </span>
            <span class="flex items-center gap-1">
              <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
                <path d="M12 .587l3.668 7.568 8.332 1.151-6.064 5.828 1.48 8.279-7.416-3.967-7.417 3.967 1.481-8.279-6.064-5.828 8.332-1.151z"/>
              </svg>
              89
            </span>
          </div>
        </article>
      </div>

      <!-- Mobile View All Link -->
      <div class="mt-8 text-center sm:hidden">
        <a href="/projects" class="text-primary hover:text-primary-dim transition-colors font-medium">
          View All Projects &rarr;
        </a>
      </div>
    </div>
  </section>

  <!-- Latest Posts Section -->
  <section class="section-gap px-6 lg:px-8 bg-surface-container-low">
    <div class="max-w-7xl mx-auto">
      <!-- Section Header -->
      <div class="flex items-center justify-between mb-12">
        <h2 class="text-3xl md:text-4xl font-bold text-on-surface">
          Latest <span class="text-primary">Posts</span>
        </h2>
        <a href="/blog" class="text-primary hover:text-primary-dim transition-colors font-medium hidden sm:block">
          View All &rarr;
        </a>
      </div>

      <!-- Posts Placeholder -->
      <div class="text-center py-12">
        <div class="inline-flex items-center justify-center w-16 h-16 bg-surface-container rounded-full mb-4">
          <svg class="w-8 h-8 text-on-surface-variant" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z" />
          </svg>
        </div>
        <p class="text-on-surface-variant text-lg mb-4">
          Blog posts coming soon...
        </p>
        <p class="text-on-surface-variant text-sm">
          I'm working on some exciting content about AI agents, development, and more.
        </p>
      </div>

      <!-- Mobile View All Link -->
      <div class="mt-8 text-center sm:hidden">
        <a href="/blog" class="text-primary hover:text-primary-dim transition-colors font-medium">
          View All Posts &rarr;
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
