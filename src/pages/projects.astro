---
// projects.astro - Projects listing page
import BaseLayout from '../layouts/BaseLayout.astro';

const projects = [
  {
    title: 'OpenClaw',
    description: 'An open-source legal document analysis tool powered by AI. Helps legal professionals process and understand complex legal documents efficiently. Features include document parsing, entity extraction, and intelligent summarization.',
    tags: ['Python', 'AI', 'NLP', 'Legal Tech'],
    category: 'Open Source',
    github: 'https://github.com/goncalovelosa/openclaw',
    stars: 128,
    icon: 'code'
  },
  {
    title: 'Autonomous Trading System',
    description: 'An AI-powered trading system that uses machine learning algorithms to analyze market patterns and execute trades autonomously. Includes comprehensive risk management and backtesting capabilities.',
    tags: ['Python', 'TensorFlow', 'Trading', 'ML'],
    category: 'AI/ML',
    github: 'https://github.com/goncalovelosa/autonomous-trading',
    stars: 89,
    icon: 'chart'
  },
  {
    title: 'AI Content Humanizer',
    description: 'A tool that helps transform AI-generated content into more natural, human-like text. Uses advanced NLP techniques to restructure and rephrase content while maintaining meaning and context.',
    tags: ['Python', 'NLP', 'GPT', 'Content'],
    category: 'AI/ML',
    github: 'https://github.com/goncalovelosa/ai-content-humanizer',
    stars: 256,
    icon: 'text'
  }
];

const iconMap: Record<string, string> = {
  code: 'M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4',
  chart: 'M13 7h8m0 0v8m0-8l-8 8-4-4-6 6',
  text: 'M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z'
};
---

<BaseLayout title="Projects | Gonçalo Velosa">
  <div class="max-w-7xl mx-auto px-6 lg:px-8 py-16 md:py-24">
    <!-- Header -->
    <header class="mb-16">
      <h1 class="text-5xl md:text-6xl lg:text-7xl font-bold text-on-surface mb-4">
        Projects<span class="text-primary">.</span>
      </h1>
      <p class="text-xl text-on-surface-variant max-w-2xl">
        A collection of open source projects and tools I've built. Focused on AI, automation, and developer productivity.
      </p>
    </header>

    <!-- Projects Grid -->
    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
      {projects.map((project) => (
        <article class="card group cursor-pointer flex flex-col">
          <!-- Header -->
          <div class="flex items-start justify-between mb-4">
            <div class="p-3 bg-surface-container-high rounded-lg">
              <svg class="w-6 h-6 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={iconMap[project.icon]} />
              </svg>
            </div>
            <span class="text-xs font-label text-on-surface-variant bg-surface-container-highest px-3 py-1 rounded-full">
              {project.category}
            </span>
          </div>

          <!-- Title -->
          <h2 class="text-xl font-bold text-on-surface mb-3 group-hover:text-primary transition-colors">
            {project.title}
          </h2>

          <!-- Description -->
          <p class="text-on-surface-variant mb-4 flex-grow">
            {project.description}
          </p>

          <!-- Tags -->
          <div class="flex flex-wrap gap-2 mb-4">
            {project.tags.map((tag) => (
              <span class="text-xs font-label text-on-surface-variant bg-surface-container-highest px-3 py-1 rounded-full">
                {tag}
              </span>
            ))}
          </div>

          <!-- Footer -->
          <div class="flex items-center justify-between pt-4 border-t border-outline-variant/10">
            <a
              href={project.github}
              target="_blank"
              rel="noopener noreferrer"
              class="flex items-center gap-2 text-sm text-on-surface-variant hover:text-primary transition-colors"
            >
              <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
                <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
              </svg>
              View on GitHub
            </a>
            <span class="flex items-center gap-1 text-sm text-on-surface-variant">
              <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
                <path d="M12 .587l3.668 7.568 8.332 1.151-6.064 5.828 1.48 8.279-7.416-3.967-7.417 3.967 1.481-8.279-6.064-5.828 8.332-1.151z"/>
              </svg>
              {project.stars}
            </span>
          </div>
        </article>
      ))}
    </div>
  </div>
</BaseLayout>
